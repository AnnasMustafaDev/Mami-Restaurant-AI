# App
DEBUG=true

# Database (SQLite — no config needed, auto-creates file)
DATABASE_URL=sqlite+aiosqlite:///./data/mami.db

# Auth
SECRET_KEY=change-me-to-a-random-string-in-production

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# OpenAI (required for chat, Phase 3)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# LiveKit (required for voice, Phase 4)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# Email (leave empty for console logging in dev)
RESEND_API_KEY=
